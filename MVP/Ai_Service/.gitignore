# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual environments ─────────────────────────────
venv/
.venv/
env/
.env/

# ── Secrets ─────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Whisper model cache (can be several GB) ──────────
models/
*.bin
*.pt
*.ot
*.gguf
~/.cache/huggingface/
~/.cache/whisper/

# ── Temporary audio/video files ──────────────────────
tmp/
temp/
*.wav
*.mp3
*.mp4
*.mkv
*.mov
*.webm

# ── Logs ─────────────────────────────────────────────
logs/
*.log

# ── Distribution / packaging ─────────────────────────
dist/
build/
*.egg-info/
.eggs/

# ── Testing & coverage ───────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Mypy / type checkers ─────────────────────────────
.mypy_cache/
.dmypy.json

# ── Ruff / linters ───────────────────────────────────
.ruff_cache/

# ── Editor ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
